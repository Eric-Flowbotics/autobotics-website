{
  "buildCommand": "",
  "outputDirectory": ".",
  "redirects": [
    { "source": "/blueprint", "destination": "/", "statusCode": 301 },
    { "source": "/toolkit", "destination": "/leak-score", "statusCode": 301 },
    { "source": "/toolkit-app", "destination": "/leak-score", "statusCode": 301 },
    { "source": "/toolkit-success", "destination": "/leak-score", "statusCode": 301 },
    { "source": "/toolkit/app", "destination": "/leak-score", "statusCode": 301 },
    { "source": "/toolkit/success", "destination": "/leak-score", "statusCode": 301 },
    { "source": "/toolkit/:path*", "destination": "/leak-score", "statusCode": 301 },
    { "source": "/checkout", "destination": "/", "statusCode": 301 },
    { "source": "/cancel", "destination": "/", "statusCode": 301 },
    { "source": "/success", "destination": "/", "statusCode": 301 },
    { "source": "/log", "destination": "/", "statusCode": 301 },
    { "source": "/5-leaks", "destination": "/get/5-leaks", "statusCode": 301 },
    { "source": "/deep-boards", "destination": "/get/deep-boards", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/thank-you", "destination": "/thank-you.html" },
    { "source": "/message-received", "destination": "/message-received.html" },
    { "source": "/leak-score", "destination": "/leak-score.html" },
    { "source": "/leak-score/results", "destination": "/leak-score-results.html" },
    { "source": "/field-reports", "destination": "/field-reports.html" },
    { "source": "/field-reports/:slug", "destination": "/field-reports/:slug.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/learn", "destination": "/learn.html" },
    { "source": "/learn/:cluster/:topic", "destination": "/learn/:cluster/:topic.html" },
    { "source": "/learn/:cluster", "destination": "/learn/:cluster.html" },
    { "source": "/get/:asset", "destination": "/get/:asset.html" }
  ]
}
